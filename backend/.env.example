ENV=development
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Emergency default: local SQLite file, no DB server needed. Swap for the
# postgresql+asyncpg:// URL below when a real Postgres instance is available.
DATABASE_URL=sqlite+aiosqlite:///./hrms.db
# DATABASE_URL=postgresql+asyncpg://hrms:hrms@localhost:5432/hrms

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=20
REFRESH_TOKEN_EXPIRE_DAYS=7

EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=no-reply@hrms.local
FRONTEND_BASE_URL=http://localhost:5173

UPLOAD_DIR=uploads
